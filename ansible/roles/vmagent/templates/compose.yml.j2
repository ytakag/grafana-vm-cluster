services:
  vmagent:
    image: "{{ (container_registry_repository | default('')) ~ '/' if container_registry_repository | default('') else '' }}victoriametrics/vmagent:latest"
    container_name: vmagent
    ports:
      - 8429:8429
    volumes:
      - vmagent-data:/vmagentdata
      - ./config/prometheus.yml:/etc/prometheus/prometheus.yml
    command:
{% for cmd in vmagent_command %}
      - "{{ cmd }}"
{% endfor %}
{% for path in vm_remote_write_path %}
      - "-remoteWrite.url=http://{{ vmauth_write_vip }}:8427{{ path }}"
{% endfor %}
    restart: always

networks:
  monitoring:
    external: true

volumes:
  vmagent-data:
