- targets:
{% for target in groups['vmagent'] %}
{% if target == inventory_hostname %}
    - vmagent:8429
{% else %}
    - {{ hostvars[target].ansible_host }}:8429
{% endif %}
{% endfor %}
  labels:
    job: vmagent

